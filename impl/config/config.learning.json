    "learning":
    {
        "split": [0.9, 0.1, 0.0],
        "sample-ratio": 1.0,
        "max-rows":
        {
            "shared":     1500000,
            "training":    400000,
            "validation":  100000,
            "test":        0
#            "test":        200000
        },
        "batch-size": 96,
        "epochs": 30,
        "progress-steps" : 100,
        "patience": 4,
        "features-dim": 57,
        "targets": ["p_throughput_log", "p_size_log"],
        "persistence-threshold": [1.0],
        "stopping-threshold": [0.001],
        "neural-network":
        {
            "hidden-layers": [128, 128, 32, 16]
        },
        "optimizer":
        {
            "lr": 2e-3,
            "weight-decay": 1e-4,
            "eps": 1e-8
        },
        "scheduler":
        {
            "factor": 0.5,
            "patience": 3,
            "min-lr": 1e-6
        },
        "penalty-weights": [1.0, 0.05]
    },
    "conversion":
    {
        "delete-OQIPstats-afterwards": true,
        "sample-ratio": 1.0,
        "distribution-ratios":
        {
            "training": 0.9,
            "validation": 0.1,
            "test": 0.0
        }
    },