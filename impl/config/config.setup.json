    "threads": -1,
    "log-level-output" : 1,
    "check-results": false,
    "editor": "nano config/config.<part>.json",
    "logs": "ls -1 ../output/logs/*.log 2>/dev/null | sort | xargs cat | tail -n",
    "readme": "less README.md",
    "out":
    {
        "machine-prefix": "Venus",
        "detailed": false,
        "formatted": false,
        "single-OQIP-file-per-O": true,
        "max-file-size-megabytes": 4000
    },
    "setup":
    {
        "create": "python -m venv .venv",
        "interpreters": 
        [
            ".venv/bin/python",
            ".venv/bin/python3.14"
        ],
        "upgrade": "-m pip install --upgrade pip",
        "install": "-m pip install",
        "libraries":
        [
            "numpy",
            "pandas",
            "torch",
            "scikit-learn",
            "pyarrow",
            "psutil"
        ]
    },