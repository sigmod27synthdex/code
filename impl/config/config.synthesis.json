    "synthesis":
    {
        "use-templated-synthdex": true,
        "top-k": 3,
        "variant": ["grad"],
        "skyline": true,
        "skyline-tolerance": 0.005,
        "top-relative": 0.05,
        "boundary-tolerance": 0.01,
        "verbose": false,
        "store-all-evaluations": true,
        "sample-size": 1000,
        "batch-evals-size": 10,
        "grad":
        {
            "max-steps": 4000,
            "lr": 0.05,
            "enable-multi-init": true,
            "objective": "weighted_log",
            "multi-start": 50,
            "adam-steps": 1200,
            "lbfgs-steps": 200,
            "patience": 60,
            "min-rel-improve": 1e-4,
            "grad-clip": 1.0,
            "cosine-anneal": true,
            "seed": 42,
            "trust-region-factor": 0.35,
            "trust-region-decay": 0.5,
            "sam-rho": 0.02,
            "perturb-on-plateau": true,
            "perturb-trials": 4,
            "perturb-scale": 0.20,
            "threshold-slow": 2e-4,
            "perturb-check-interval": 60,
            "sobol-local": true,
            "local-sobol-points": 12,
            "span-grad-normalize": true,
            "weight-temperature": 1.0,
            "revert-on-degradation": true,
            "max-param-jump-frac": 0.55,
            "diagnostics-level": 2
        },
        "grid":
        {
            "step-resolution-and-top-k": 
            [
                [6, 20],
                [3, 10],
                [2, 2]
            ],
            "candidates-limit": 100000,
            "objective": "weighted_log",
            "weight-temperature": 1.0
        },
        "intervals":
        {
            "slices": 20,
            "clustering":
            {
                "contiguous": true
            },
        },
    },
    "prediction":
    {
        "predict-before-run": false,
        "top-k": 0
    },
    "accuracy":
    {
        "num-object-collections": 100,
        "num-indices-per-OQ": 10,
        "emit-training-data": true,
        "from-parquet": false,
        "from-parquet-aggregate-OI": true
    },